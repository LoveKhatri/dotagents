      "description": "[OpenAI] GPT-5.5"
    },
    "oa-gpt-5.4-mini": {
      "mode": "subagent",
      "hidden": true,
      "model": "openai/gpt-5.4-mini",
      "description": "[OpenAI] GPT-5.4 Mini"
    },
    "oa-gpt-5.3-codex": {
      "mode": "subagent",
      "hidden": true,
      "model": "openai/gpt-5.3-codex",
