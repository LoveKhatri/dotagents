      "hidden": true,
      "model": "opencode-go/qwen3.7-max",
      "description": "[OpenCode Go] Qwen 3.7 Max (950 req/5h, 2,390/wk, 4,770/mo)"
    },
    "ogo-qwen3.7-plus": {
      "mode": "subagent",
      "hidden": true,
      "model": "opencode-go/qwen3.7-plus",
      "description": "[OpenCode Go] Qwen 3.7 Plus (4,300 req/5h, 10,800/wk, 21,600/mo)"
    },
    "ogo-deepseek-v4-pro": {
      "mode": "subagent",
      "hidden": true,
      "model": "opencode-go/deepseek-v4-pro",
      "description": "[OpenCode Go] DeepSeek V4 Pro (3,450 req/5h, 8,550/wk, 17,150/mo)"
    },
    "ogo-deepseek-v4-flash": {
      "mode": "subagent",
      "hidden": true,
      "model": "opencode-go/deepseek-v4-flash",
      "description": "[OpenCode Go] DeepSeek V4 Flash (31,650 req/5h, 79,050/wk, 158,150/mo)"
    },
    "ogo-mimo-v2.5": {
      "mode": "subagent",
      "hidden": true,
      "model": "opencode-go/mimo-v2.5",
      "description": "[OpenCode Go] MiMo V2.5 (30,100 req/5h, 75,200/wk, 150,400/mo)"
    },
    "ogo-qwen3.6-plus": {
      "mode": "subagent",
      "hidden": true,
      "model": "opencode-go/qwen3.6-plus",
      "description": "[OpenCode Go] Qwen 3.6 Plus (3,300 req/5h, 8,200/wk, 16,300/mo)"
