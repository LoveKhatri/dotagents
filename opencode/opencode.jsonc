    },
    "ogo-glm-5.1": {
      "mode": "subagent",
      "hidden": true,
      "model": "opencode-go/glm-5.1",
      "description": "[OpenCode Go] GLM-5.1 (880 req/5h, 2,150/wk, 4,300/mo)"
    },
    "ogo-kimi-k2.7-code": {
      "mode": "subagent",
      "hidden": true,
      "model": "opencode-go/kimi-k2.7-code",
      "description": "[OpenCode Go] Kimi K2.7 Code (1,350 req/5h, 4,630/wk, 9,250/mo)"
    },
    "ogo-mimo-v2.5-pro": {
      "mode": "subagent",
      "hidden": true,
      "model": "opencode-go/mimo-v2.5-pro",
      "description": "[OpenCode Go] MiMo V2.5 Pro (3,250 req/5h, 8,150/wk, 16,300/mo)"
    },
    "ogo-minimax-m3": {
