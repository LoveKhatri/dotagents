{
  "plugin": [
    "opencode-antigravity-auth@latest"
  ],
  "$schema": "https://opencode.ai/config.json",
  "shell": "zsh",
  "provider": {
    "commandcode": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "CommandCode",
      "options": {
        "baseURL": "http://localhost:55990/v1"
      },
      "models": {
        "deepseek/deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro",
        },
        "deepseek/deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash"
        },
        "moonshotai/Kimi-K2.7-Code": {
          "name": "Kimi K2.7 Code"
        },
        "moonshotai/Kimi-K2.6": {
          "name": "Kimi K2.6"
        },
        "moonshotai/Kimi-K2.5": {
          "name": "Kimi K2.5"
        },
        "zai-org/GLM-5.1": {
          "name": "GLM-5.1"
        },
        "zai-org/GLM-5": {
          "name": "GLM-5"
        },
        "MiniMaxAI/MiniMax-M3": {
          "name": "MiniMax M3"
        },
        "MiniMaxAI/MiniMax-M2.7": {
          "name": "MiniMax M2.7"
        },
        "MiniMaxAI/MiniMax-M2.5": {
          "name": "MiniMax M2.5"
        },
        "xiaomi/mimo-v2.5-pro": {
          "name": "MiMo V2.5 Pro"
        },
        "xiaomi/mimo-v2.5": {
          "name": "MiMo V2.5"
        },
        "Qwen/Qwen3.7-Max": {
          "name": "Qwen 3.7 Max"
        },
        "Qwen/Qwen3.7-Plus": {
          "name": "Qwen 3.7 Plus"
        },
        "Qwen/Qwen3.6-Max-Preview": {
          "name": "Qwen 3.6 Max Preview"
        },
        "Qwen/Qwen3.6-Plus": {
          "name": "Qwen 3.6 Plus"
        }
      }
    }
  },
  "mcp": {
    "code-review-graph": {
      "enabled": true,
      "command": [
        "uvx",
        "code-review-graph",
        "serve"
      ],
      "type": "local",
      "environment": {}
    }
  },
}