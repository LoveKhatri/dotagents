{
  "plugin": [
    "opencode-antigravity-auth@latest"
  ],
  "$schema": "https://opencode.ai/config.json",
  "shell": "zsh",
  "provider": {
    "commandcode": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "CommandCode",
      "options": {
        "baseURL": "http://localhost:55990/v1"
      },
      "models": {
        "deepseek/deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro"
        },
        "deepseek/deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash"
        },
        "moonshotai/Kimi-K2.7-Code": {
          "name": "Kimi K2.7 Code"
        },
        "moonshotai/Kimi-K2.6": {
          "name": "Kimi K2.6"
        },
        "moonshotai/Kimi-K2.5": {
          "name": "Kimi K2.5"
        },
        "zai-org/GLM-5.1": {
          "name": "GLM-5.1"
        },
        "zai-org/GLM-5": {
          "name": "GLM-5"
        },
        "MiniMaxAI/MiniMax-M3": {
          "name": "MiniMax M3"
        },
        "MiniMaxAI/MiniMax-M2.7": {
          "name": "MiniMax M2.7"
        },
        "MiniMaxAI/MiniMax-M2.5": {
          "name": "MiniMax M2.5"
        },
        "xiaomi/mimo-v2.5-pro": {
          "name": "MiMo V2.5 Pro"
        },
        "xiaomi/mimo-v2.5": {
          "name": "MiMo V2.5"
        },
        "Qwen/Qwen3.7-Max": {
          "name": "Qwen 3.7 Max"
        },
        "Qwen/Qwen3.7-Plus": {
          "name": "Qwen 3.7 Plus"
        },
        "Qwen/Qwen3.6-Max-Preview": {
          "name": "Qwen 3.6 Max Preview"
        },
        "Qwen/Qwen3.6-Plus": {
          "name": "Qwen 3.6 Plus"
        }
      }
    }
  },
  "agent": {
    "cc-deepseek-v4-pro": {
      "mode": "subagent",
      "hidden": true,
      "model": "commandcode/deepseek/deepseek-v4-pro",
      "description": "[CommandCode] DeepSeek V4 Pro"
    },
    "cc-deepseek-v4-flash": {
      "mode": "subagent",
      "hidden": true,
      "model": "commandcode/deepseek/deepseek-v4-flash",
      "description": "[CommandCode] DeepSeek V4 Flash"
    },
    "cc-mimo-v2.5-pro": {
      "mode": "subagent",
      "hidden": true,
      "model": "commandcode/xiaomi/mimo-v2.5-pro",
      "description": "[CommandCode] MiMo V2.5 Pro"
    },
    "cc-mimo-v2.5": {
      "mode": "subagent",
      "hidden": true,
      "model": "commandcode/xiaomi/mimo-v2.5",
      "description": "[CommandCode] MiMo V2.5"
    },
    "cc-kimi-k2.7-code": {
      "mode": "subagent",
      "hidden": true,
      "model": "commandcode/moonshotai/Kimi-K2.7-Code",
      "description": "[CommandCode] Kimi K2.7 Code"
    },
    "cc-kimi-k2.6": {
      "mode": "subagent",
      "hidden": true,
      "model": "commandcode/moonshotai/Kimi-K2.6",
      "description": "[CommandCode] Kimi K2.6"
    },
    "cc-glm-5.1": {
      "mode": "subagent",
      "hidden": true,
      "model": "commandcode/zai-org/GLM-5.1",
      "description": "[CommandCode] GLM-5.1"
    },
    "cc-minimax-m3": {
      "mode": "subagent",
      "hidden": true,
      "model": "commandcode/MiniMaxAI/MiniMax-M3",
      "description": "[CommandCode] MiniMax M3"
    },
    "cc-qwen3.7-max": {
      "mode": "subagent",
      "hidden": true,
      "model": "commandcode/Qwen/Qwen3.7-Max",
      "description": "[CommandCode] Qwen 3.7 Max"
    },
    "cc-qwen3.7-plus": {
      "mode": "subagent",
      "hidden": true,
      "model": "commandcode/Qwen/Qwen3.7-Plus",
      "description": "[CommandCode] Qwen 3.7 Plus"
    },
    "gh-haiku-4.5": {
      "mode": "subagent",
      "hidden": true,
      "model": "github-copilot/claude-haiku-4.5",
      "description": "[GitHub Copilot] Claude Haiku 4.5"
    },
    "gh-gemini-3.1-pro": {
      "mode": "subagent",
